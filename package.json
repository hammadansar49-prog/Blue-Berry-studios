{
  "name": "karobar",
  "version": "1.0.0",
  "description": "KAROBAR - Billing & POS desktop app",
  "main": "electron/main.js",
  "author": "Hammad Ansar",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "set ELECTRON_START_URL=http://localhost:5500&& electron .",
    "icon": "node scripts/make-icon.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.58",
    "electron": "22.3.27",
    "electron-builder": "24.13.3",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.karobar.app",
    "productName": "KAROBAR",
    "copyright": "Copyright © Hammad Ansar",
    "files": [
      "electron/**/*",
      "index.html",
      "app.js",
      "styles.css",
      "firebase-config.js",
      "assets/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "artifactName": "KAROBAR-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KAROBAR",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
