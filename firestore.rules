rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- A store's data lives at users/{ownerUid} ----
    // The owner has full control. Staff listed in memberUids can read/write
    // the store data, but CANNOT change the membership list itself.
    match /users/{ownerUid} {
      allow read: if request.auth != null && (
        request.auth.uid == ownerUid ||
        ('memberUids' in resource.data && request.auth.uid in resource.data.memberUids)
      );
      allow write: if request.auth != null && (
        // owner: full control (also covers first-time create when resource is null)
        request.auth.uid == ownerUid ||
        // member: may edit store data, but not the memberUids list
        (
          'memberUids' in resource.data &&
          request.auth.uid in resource.data.memberUids &&
          request.resource.data.memberUids == resource.data.memberUids
        )
      );
    }

    // ---- staffMap/{staffUid} = { ownerUid, username } ----
    // Lets a staff device discover which store it belongs to after login.
    // Only an owner can create a mapping that points to themselves.
    match /staffMap/{staffUid} {
      allow read: if request.auth != null && (
        request.auth.uid == staffUid ||
        (resource != null && resource.data.ownerUid == request.auth.uid)
      );
      allow create, update: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Everything else denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
