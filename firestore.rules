rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- A store's data lives at users/{ownerUid} ----
    // Owner has full control. Staff/branches listed in memberUids can read.
    // Public read allowed for branch code-based login (branchLookup validates the code first).
    match /users/{ownerUid} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == ownerUid
      );
    }

    // ---- staffMap/{staffUid} = { ownerUid, username } ----
    match /staffMap/{staffUid} {
      allow read: if request.auth != null && (
        request.auth.uid == staffUid
      );
      allow create, update: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
    }

    // ---- branches/{branchId} = branch data ----
    match /branches/{branchId} {
      allow read: if request.auth != null && (
        request.auth.uid == branchId ||
        (resource != null && resource.data.ownerUid == request.auth.uid)
      );
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null && (
        request.auth.uid == branchId ||
        (resource != null && resource.data.ownerUid == request.auth.uid)
      );
      allow delete: if request.auth != null && (
        resource != null && resource.data.ownerUid == request.auth.uid
      );
    }

    // ---- branchMap/{branchUid} = branch to owner mapping ----
    match /branchMap/{branchUid} {
      allow read: if request.auth != null && (
        request.auth.uid == branchUid
      );
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && (
        request.auth.uid == branchUid ||
        (resource != null && resource.data.ownerUid == request.auth.uid)
      );
    }

    // ---- branchLookup/{code} = public branch code lookup for login ----
    match /branchLookup/{code} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ---- globalBranchCodes/{code} = global branch code uniqueness ----
    match /globalBranchCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Everything else denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
